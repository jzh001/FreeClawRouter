# FreeClawRouter — API Keys Template
# Copy this file to .env and fill in your free-tier keys.
# Leave blank to skip a provider (FreeClawRouter will ignore it automatically).

# Cerebras — 14,400 req/day free, 1M tokens/day free
# Sign up: https://cloud.cerebras.ai  (no credit card required)
CEREBRAS_API_KEY=

# Groq — 14,400 req/day free (8B model), 1,000 req/day (70B model)
# Sign up: https://console.groq.com  (no credit card required)
GROQ_API_KEY=

# Google AI Studio (Gemini API) — 250 req/day free, 1M token context
# Sign up: https://aistudio.google.com  (free, no credit card)
GOOGLE_AI_API_KEY=

# OpenRouter — 200 req/day free (with payment method), 29 free models
# Sign up: https://openrouter.ai  (no credit card for 50 RPD basic tier)
OPENROUTER_API_KEY=

# NVIDIA Build (NIM) — ~40 req/min free, requires phone verification
# Sign up: https://build.nvidia.com
NVIDIA_API_KEY=

# SambaNova Cloud — 200K tokens/day free, 30 RPM
# Sign up: https://cloud.sambanova.ai  (no credit card required)
SAMBANOVA_API_KEY=

# Mistral AI — Experiment plan, ~500K TPM free (not for commercial use)
# Sign up: https://console.mistral.ai
MISTRAL_API_KEY=
